<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:CompileBindings="False"
        x:Class="StolyarovaDemo1703.OrderWindow"
        Title="OrderWindow">
  <DockPanel Margin="15">
	  <Button Content="Назад" Click="Button_Click" DockPanel.Dock="Top"/>
      <ListBox Name="OrdersBox">
		  <ListBox.ItemTemplate>
			  <DataTemplate>
				  <Grid ColumnDefinitions="500,100">
					  <Grid RowDefinitions="*,*,*,*">
						  <TextBlock Text="{Binding OrderId}"/>
                          <TextBlock Text="{Binding Status.StatusName}" Grid.Row="1"/>
                          <TextBlock Text="{Binding Address.AddressName}" Grid.Row="2"/>
                          <TextBlock Text="{Binding OrderCreateDate}" Grid.Row="3"/>
                      </Grid>
                  </Grid>
              </DataTemplate>
          </ListBox.ItemTemplate>
      </ListBox>
  </DockPanel>
</Window>
